LIST_REFRESH_MAX_AGE_S = 15 * 60


def _refresh_stale_slots(names: list[str], *, force: bool = False) -> None:
    """Refresh slots with stale usage data. If force, refresh all regardless."""
    targets = names if force else [
        n for n in names
        if not _usage_is_fresh(load_json(slot_dir(n) / "usage.json"))
    ]
    if not targets:
        return
    msg = f"refreshing {len(targets)} slot{'s' if len(targets) != 1 else ''}…"
    print(_c(DIM, msg), file=sys.stderr, flush=True)
    for n in targets:
        err = _refresh_slot(n)
        if err:
            print(_c(DIM, f"  {n}: {err}"), file=sys.stderr)


def _maybe_refresh_credentials(name: str, blob: str) -> tuple[str, str | None]:
    """If the slot's access token is expired, refresh and persist the new blob.

    Also syncs active credentials when the slot matched the currently-active
    login, so the running `claude` picks up the rotated token without a manual
    `cc-auth switch`. Returns (blob_to_use, err). On refresh failure, the old
    blob is returned so downstream calls still get attempted (and surface their
    own 401 if the token is truly dead).
    """
    if not token_is_expired(blob):
        return blob, None
    active_before = read_active_credentials()
    was_active = (
        active_before is not None
        and extract_access_token(active_before) == extract_access_token(blob)
    )
    new_blob, err = refresh_blob(blob)
    if err or new_blob is None:
        return blob, err
    slot_creds_write(name, new_blob)
    if was_active:
        write_active_credentials(new_blob)
    return new_blob, None


def _refresh_slot(name: str) -> str | None:
    """Fetch fresh profile + usage for a slot; write to disk. Return err or None.

    Transparently refreshes the OAuth access token if it's expired (or about
    to expire), and retries once on 401 in case expiry is wrong or the server
    rejected the token early.
    """
    blob = slot_creds_read(name)
    if blob is None:
        return "missing credentials"

    blob, refresh_err = _maybe_refresh_credentials(name, blob)
    token = extract_access_token(blob)
    if not token:
        return refresh_err or "no access token"

    profile, usage, err = fetch_profile_and_usage(token)

    # server rejected despite our expiry check — try one forced refresh + retry
    if err and "401" in err and refresh_err is None:
        new_blob, rerr = refresh_blob(blob)
        if new_blob is not None:
            slot_creds_write(name, new_blob)
            active = read_active_credentials()
            if active and extract_access_token(active) == token:
                write_active_credentials(new_blob)
            token = extract_access_token(new_blob)
            if token:
                profile, usage, err = fetch_profile_and_usage(token)
        elif rerr:
            err = f"{err}; {rerr}"

    d = slot_dir(name)
    d.mkdir(parents=True, exist_ok=True)
    if profile is not None:
        (d / "profile.json").write_text(json.dumps(profile, indent=2))
    if usage is not None:
        usage["_fetched_at"] = datetime.now(timezone.utc).isoformat()
        (d / "usage.json").write_text(json.dumps(usage, indent=2))
    # a failed refresh is the root cause of any subsequent 401 — surface that
    # (e.g. "invalid_grant" when the refresh token was revoked) instead of the
    # downstream symptom.
    if refresh_err and err and "401" in err:
        return f"{refresh_err} (re-login required: `claude` then `cc-auth save {name}`)"
    return err or refresh_err


def _usage_is_fresh(usage: dict | None, max_age_s: int = LIST_REFRESH_MAX_AGE_S) -> bool:
    """Decide if cached usage avoids a refresh.

    Fresh if either:
      - it was fetched within max_age_s, OR
      - a bucket is saturated (>=100%) with a future resets_at — utilization
        can't change until that rollover, so re-polling is wasted.
    """
    if not usage:
        return False
    now = datetime.now(timezone.utc)
    fetched = usage.get("_fetched_at")
    if fetched:
        try:
            dt = datetime.fromisoformat(fetched.replace("Z", "+00:00"))
            if (now - dt).total_seconds() < max_age_s:
                return True
        except ValueError:
            pass
    for key in ("five_hour", "seven_day"):
        block = usage.get(key) or {}
        pct = block.get("utilization")
        resets = block.get("resets_at")
        if not (isinstance(pct, (int, float)) and pct >= 100 and resets):
            continue
        try:
            reset_dt = datetime.fromisoformat(resets.replace("Z", "+00:00"))
        except ValueError:
            continue
        if reset_dt > now:
            return True
    return False


def cmd_refresh(*args: str) -> None:
    # default skips slots whose cached usage is still inside the freshness
    # window (or saturated with a future reset, where re-polling can't change
    # anything). --force ignores the cache and always re-polls.
    force = False
    name: str | None = None
    for a in args:
        if a == "--force":
            force = True
        elif a == "--if-stale":
            pass  # accepted for back-compat; this is now the default
        elif a.startswith("--"):
            die(f"refresh: unknown flag {a}")
        elif name is None:
            name = a
        else:
            die("refresh: too many positional arguments")
    names = [name] if name else list_slot_names()
    if not names:
        die("No slots to refresh.")
    for n in names:
        if not force and _usage_is_fresh(load_json(slot_dir(n) / "usage.json")):
            print(f"{n}: skip (fresh)")
            continue
        err = _refresh_slot(n)
        status = "ok" if err is None else f"WARN {err}"
        print(f"{n}: {status}")


def cmd_ping(name: str | None) -> None:
    """Send a near-zero-cost message via `claude -p` to start the 5h/7d windows.

    Drives the real `claude` CLI rather than calling /v1/messages directly, so
    the request is indistinguishable from any other Claude Code traffic
    (correct system prompt, user agent, request shape). The slot's OAuth
    access token is passed via the CLAUDE_CODE_OAUTH_TOKEN env var, and a
    fresh CLAUDE_CONFIG_DIR keeps the user's main ~/.claude untouched (no
    history pollution, no MCP/agent re-init, no keychain swap).
    """
    if not shutil.which("claude"):
        die("ping: `claude` CLI not found on PATH")

    if name:
        blob = slot_creds_read(name)
        if blob is None:
            die(f"No such slot: {name}")
        blob, err = _maybe_refresh_credentials(name, blob)
        if err and token_is_expired(blob):
            die(f"refresh: {err}")
        target = name
    else:
        target = find_current_slot()
        blob = read_active_credentials()
        if not blob:
            die("No active credentials.")
        if token_is_expired(blob):
            new_blob, err = refresh_blob(blob)
            if new_blob:
                write_active_credentials(new_blob)
                if target:
                    slot_creds_write(target, new_blob)
                blob = new_blob
            elif err:
                die(f"refresh: {err}")

    token = extract_access_token(blob)
    if not token:
        die("ping: no access token available")

    import tempfile
    tmpdir = tempfile.mkdtemp(prefix="cc-auth-ping-")
    env = {**os.environ, "CLAUDE_CONFIG_DIR": tmpdir, "CLAUDE_CODE_OAUTH_TOKEN": token}
    # subscription type isn't strictly required, but Claude Code reads it from
    # the env when present and skips a profile lookup that's redundant for us.
    try:
        sub = json.loads(blob).get("claudeAiOauth", {}).get("subscriptionType")
        if sub:
            env["CLAUDE_CODE_SUBSCRIPTION_TYPE"] = sub
    except (json.JSONDecodeError, AttributeError):
        pass

    label = target or "(active)"
    print(f"ping {label}: sending via `claude -p`…", flush=True)
    try:
        r = subprocess.run(
            ["claude", "--print", "--model", PING_MODEL,
             "--no-session-persistence", PING_PROMPT],
            env=env, capture_output=True, text=True, timeout=60,
        )
    except subprocess.TimeoutExpired:
        shutil.rmtree(tmpdir, ignore_errors=True)
        die("ping: claude -p timed out after 60s")
    finally:
        shutil.rmtree(tmpdir, ignore_errors=True)

    if r.returncode != 0:
        err_tail = (r.stderr or r.stdout or "").strip().splitlines()[-3:]
        die(f"ping: claude exit {r.returncode}\n  " + "\n  ".join(err_tail))

    reply = (r.stdout or "").strip().splitlines()[0:1]
    print(f"ping {label}: ok ({reply[0][:80] if reply else 'no output'})")
    if target:
        rerr = _refresh_slot(target)
        if rerr:
            print(f"  warning: {rerr}", file=sys.stderr)


def _fmt_util(block: dict | None) -> str:
    if not block:
        return "-"
    u = block.get("utilization")
    return f"{u:>5.1f}%" if isinstance(u, (int, float)) else "-"


def _fmt_reset(iso: str | None) -> str:
    if not iso:
        return "-"
    try:
        dt = datetime.fromisoformat(iso.replace("Z", "+00:00"))
        delta = dt - datetime.now(timezone.utc)
        hours = delta.total_seconds() / 3600
        if hours < 0:
            return "expired"
        if hours < 24:
            return f"in {hours:.1f}h"
        return f"in {hours/24:.1f}d"
    except ValueError:
        return iso


