# ─── update check ──────────────────────────────────────────────────────────

def _parse_version(s: str) -> tuple[int, ...]:
    """Loose semver parse — leading 'v' tolerated, non-numeric components → 0."""
    out: list[int] = []
    for part in s.lstrip("v").split("."):
        # strip pre-release/build suffix on the first non-digit run, e.g. "0.2.0-rc1"
        digits = ""
        for ch in part:
            if ch.isdigit():
                digits += ch
            else:
                break
        out.append(int(digits) if digits else 0)
    return tuple(out) or (0,)


def _check_for_update(*, force: bool = False) -> str | None:
    """Return latest published version if newer than __version__, else None.

    Caches the network check for UPDATE_CHECK_TTL_S so daily users pay one
    GitHub API call per day. Tries Releases first (the curated artifact);
    falls back to Tags so a single `git tag vX.Y.Z && git push --tags` is
    enough to make a new version visible without cutting a Release.
    """
    if os.environ.get("CC_AUTH_NO_UPDATE_CHECK"):
        return None
    cache = load_json(UPDATE_CHECK_FILE) or {}
    now = datetime.now(timezone.utc)
    if not force and cache.get("checked_at"):
        try:
            checked = datetime.fromisoformat(cache["checked_at"].replace("Z", "+00:00"))
            if (now - checked).total_seconds() < UPDATE_CHECK_TTL_S:
                latest = cache.get("latest")
                if latest and _parse_version(latest) > _parse_version(__version__):
                    return latest.lstrip("v")
                return None
        except ValueError:
            pass

    headers = {"User-Agent": f"cc-auth/{__version__}",
               "Accept": "application/vnd.github+json"}
    latest: str | None = None
    for path in (f"/repos/{GITHUB_REPO}/releases/latest",
                 f"/repos/{GITHUB_REPO}/tags"):
        try:
            req = urllib.request.Request(f"https://api.github.com{path}", headers=headers)
            with urllib.request.urlopen(req, timeout=3) as r:
                data = json.loads(r.read())
            if isinstance(data, dict):
                latest = data.get("tag_name")
            elif isinstance(data, list) and data:
                latest = data[0].get("name")
            if latest:
                break
        except Exception:
            continue

    cache["checked_at"] = now.isoformat()
    if latest:
        cache["latest"] = latest
    try:
        UPDATE_CHECK_FILE.parent.mkdir(parents=True, exist_ok=True)
        UPDATE_CHECK_FILE.write_text(json.dumps(cache))
    except OSError:
        pass

    if latest and _parse_version(latest) > _parse_version(__version__):
        return latest.lstrip("v")
    return None


def _print_update_hint(*, when_current: bool = False) -> None:
    """Print the one-line update hint to stderr if a newer version exists.

    Stays silent when already on the latest version unless when_current is set
    (used by `cc-auth version`, where "up to date" is the affirmative answer).
    """
    try:
        latest = _check_for_update()
    except Exception:
        return
    color = _color_enabled(sys.stderr)
    if latest:
        line = (f"  update available: {__version__} → {latest}  "
                f"(https://github.com/{GITHUB_REPO}/releases)")
        print(_c(AMBER, line, force=color), file=sys.stderr)
    elif when_current:
        print(_c(DIM, "  up to date", force=color), file=sys.stderr)


def cmd_version() -> None:
    # force the network check (bypassing the 24h cache) so an explicit
    # `cc-auth version` always reflects the live remote state. the hint
    # itself is printed by main() via UPDATE_HINT_CMDS.
    print(f"cc-auth {__version__}", flush=True)
    try:
        _check_for_update(force=True)
    except Exception:
        pass


