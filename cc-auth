COMMANDS = {
    "save": (cmd_save, "0-1"),
    "switch": (cmd_switch, "0-1"),
    "list": (cmd_list, 0),
    "current": (cmd_current, 0),
    "delete": (cmd_delete, 1),
    "refresh": (cmd_refresh, "*"),
    "ping": (cmd_ping, "0-1"),
    "stats": (cmd_stats, "0-1"),
    "whoami": (cmd_whoami, 0),
    "version": (cmd_version, 0),
}

UPDATE_HINT_CMDS = {"list", "current", "whoami", "save", "ping", "version"}


def migrate_legacy_home() -> None:
    """One-shot move from ~/.cc-auth → ~/.claude/cc-auth.

    Runs only if the legacy dir exists and the new one does not. Preserves the
    layout (slots/<name>/profile.json etc). On macOS the sensitive OAuth blobs
    already live in Keychain, so what moves is just metadata; on Linux the
    chmod-600 credentials.json files move along with their parent dirs.
    """
    if not LEGACY_CC_HOME.is_dir() or CC_HOME.exists():
        return
    CC_HOME.parent.mkdir(parents=True, exist_ok=True)
    try:
        LEGACY_CC_HOME.rename(CC_HOME)
    except OSError as e:
        print(f"warning: could not migrate {LEGACY_CC_HOME} → {CC_HOME}: {e}",
              file=sys.stderr)
        return
    print(f"migrated {LEGACY_CC_HOME} → {CC_HOME}", file=sys.stderr)


SYNC_BEFORE_CMDS = {"list", "current", "refresh", "stats", "switch", "whoami", "ping"}


def main() -> None:
    migrate_legacy_home()
    SLOTS_DIR.mkdir(parents=True, exist_ok=True)
    argv = sys.argv[1:]
    if not argv or argv[0] in ("-h", "--help", "help"):
        print(__doc__)
        return
    cmd = argv[0]
    args = argv[1:]
    if cmd not in COMMANDS:
        die(f"Unknown command: {cmd}\n\n{__doc__}")
    # heal rotation drift before any read/refresh that depends on slot blobs.
    # `save` and `delete` intentionally skip — save explicitly captures the
    # active blob and delete shouldn't trigger a network call.
    if cmd in SYNC_BEFORE_CMDS:
        try:
            sync_active_to_slot(verbose=True)
        except Exception as e:
            print(_c(DIM, f"(sync skipped: {e})"), file=sys.stderr)
    fn, arity = COMMANDS[cmd]
    if arity == 0:
        if args:
            die(f"{cmd} takes no arguments")
        fn()
    elif arity == 1:
        if len(args) != 1:
            die(f"{cmd} requires exactly one argument")
        fn(args[0])
    elif arity == "0-1":
        if len(args) > 1:
            die(f"{cmd} takes at most one argument")
        fn(args[0] if args else None)
    elif arity == "*":
        fn(*args)

    if cmd in UPDATE_HINT_CMDS:
        _print_update_hint(when_current=(cmd == "version"))


if __name__ == "__main__":
    main()
