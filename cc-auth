#!/usr/bin/env python3
"""cc-auth — save/switch/inspect Claude Code auth slots.

Storage:
  - credentials: macOS Keychain (service "cc-auth", account = slot name);
                 on Linux, ~/.claude/cc-auth/slots/<name>/credentials.json (chmod 600)
  - ~/.claude/cc-auth/slots/<name>/profile.json: last response from /api/oauth/profile
  - ~/.claude/cc-auth/slots/<name>/usage.json:   last response from /api/oauth/usage
                                                 (with _fetched_at added)

Usage:
  cc-auth save [<name>]       snapshot active credentials, fetch profile+usage
                              (name defaults to the logged-in account email)
  cc-auth switch [<name>]     write slot credentials back into keychain / creds file
                              (no name → fzf picker, or numbered prompt as fallback)
  cc-auth list                list slots with cached email + tier
  cc-auth current             name of the slot matching active credentials (if any)
  cc-auth delete <name>       remove a slot
  cc-auth refresh [<name>] [--force]
                              re-fetch profile+usage for one slot (or all);
                              skips slots with fresh cached usage unless --force
  cc-auth ping [<name>]       send a near-zero-cost `claude -p hi` to start
                              the slot's 5h/7d session windows (uses real
                              claude CLI; isolated CLAUDE_CONFIG_DIR so the
                              user's main session is untouched)
  cc-auth stats [<name>]      table of cached usage per slot (or one)
  cc-auth whoami              active account email+tier (from fresh profile call)
  cc-auth version             show installed version + check GitHub for newer

Set CC_AUTH_NO_UPDATE_CHECK=1 to disable the daily update check.
"""
from __future__ import annotations

import hashlib
import json
import os
import shutil
import subprocess
import sys
import urllib.error
import urllib.request
from datetime import datetime, timezone
from pathlib import Path

__version__ = "0.2.1"
GITHUB_REPO = "rsnodgrass/claude-code-auth"

KEYCHAIN_SERVICE = "Claude Code-credentials"
KEYCHAIN_ACCOUNT = os.environ.get("USER", "")
LINUX_CREDS_FILE = Path.home() / ".claude" / ".credentials.json"

SLOT_KEYCHAIN_SERVICE = "cc-auth"

CC_HOME = Path.home() / ".claude" / "cc-auth"
SLOTS_DIR = CC_HOME / "slots"
LEGACY_CC_HOME = Path.home() / ".cc-auth"  # pre-move location; migrated on first run
# memo: access-token hash → account email. avoids re-fetching /oauth/profile on
# every cc-auth invocation just to identify whose creds are active. invalidated
# automatically whenever the active accessToken rotates (the hash changes).
ACTIVE_IDENTITY_CACHE = CC_HOME / "active-identity.json"

UPDATE_CHECK_FILE = CC_HOME / "update-check.json"
UPDATE_CHECK_TTL_S = 24 * 3600  # one network call per day, max

API_BASE = "https://api.anthropic.com"
OAUTH_BETA = "oauth-2025-04-20"

# OAuth token refresh — Claude Code's public client id + token endpoint.
# Cloudflare in front of console.anthropic.com 403s the stock urllib UA, so
# every request to these hosts needs an explicit User-Agent.
OAUTH_TOKEN_URL = "https://console.anthropic.com/v1/oauth/token"
OAUTH_CLIENT_ID = "9d1c250a-e61b-44d9-88ed-5944d1962f5e"
USER_AGENT = "cc-auth/1.0"

# refresh proactively if the token expires within this many seconds
REFRESH_SKEW_S = 60

# ping uses the cheapest available model + max_tokens=1 to start the rolling
# 5h/7d rate-limit windows with the smallest possible quota draw.
PING_MODEL = "claude-haiku-4-5"
PING_PROMPT = "hi"


# ─── color + visual helpers (Tufte-ish: muted palette, data-ink ratio) ─────
# Respect NO_COLOR and non-TTY. 256-color ANSI for muted semantic palette.

def _color_enabled(stream=sys.stdout) -> bool:
    if os.environ.get("NO_COLOR"):
        return False
    if os.environ.get("CC_AUTH_FORCE_COLOR"):
        return True
    return hasattr(stream, "isatty") and stream.isatty()


def _c(code: str, s: str, *, force: bool = False) -> str:
    if not (force or _color_enabled()):
        return s
    return f"\033[{code}m{s}\033[0m"

# muted palette (xterm-256)
SAGE, AMBER, BRICK, DIM, LABEL, ACCENT = "38;5;108", "38;5;179", "38;5;167", "38;5;244", "38;5;250", "38;5;111"
BOLD = "1"


def severity_code(pct: float | None) -> str:
    if pct is None:
        return DIM
    if pct < 50:
        return SAGE
    if pct < 80:
        return AMBER
    return BRICK


def sparkbar(pct: float | None, width: int = 10, *, force_color: bool = False) -> str:
    """Horizontal sparkbar using eighth blocks for sub-cell precision."""
    blocks = " ▏▎▍▌▋▊▉█"  # 0..8 eighths
    if pct is None:
        body = "·" * width
        return _c(DIM, body, force=force_color)
    p = max(0.0, min(100.0, float(pct)))
    eighths = round(p / 100.0 * width * 8)
    full, rem = divmod(eighths, 8)
    body = "█" * full
    if rem:
        body += blocks[rem]
    body = body.ljust(width, "·")
    return _c(severity_code(p), body, force=force_color)


def color_pct(pct: float | None, *, force_color: bool = False) -> str:
    if pct is None:
        return _c(DIM, "    -", force=force_color)
    return _c(severity_code(pct), f"{pct:>4.0f}%", force=force_color)


def _clock(dt_local: datetime) -> str:
    """'5pm', '5:30pm', or 'Fri 5pm' for >24h out."""
    h12 = dt_local.strftime("%-I")
    ampm = dt_local.strftime("%p").lower()
    t = f"{h12}{ampm}" if dt_local.minute == 0 else f"{h12}:{dt_local.minute:02d}{ampm}"
    return t


def color_reset_hint(iso: str | None, *, force_color: bool = False) -> str:
    """Return coloured hint like '3.0h @ 5pm' / '2.8d @ Fri 5pm' / 'expired'."""
    if not iso:
        return _c(DIM, "—", force=force_color)
    try:
        dt = datetime.fromisoformat(iso.replace("Z", "+00:00"))
    except ValueError:
        return iso
    hours = (dt - datetime.now(timezone.utc)).total_seconds() / 3600
    if hours < 0:
        return _c(BRICK, "expired", force=force_color)
    local = dt.astimezone()
    if hours < 24:
        rel = f"{hours:>4.1f}h"
        clock = _clock(local)
    else:
        rel = f"{hours/24:>4.1f}d"
        clock = f"{local.strftime('%a')} {_clock(local)}"
    # sooner = warmer. <1h red, <6h amber, else sage.
    code = BRICK if hours < 1 else AMBER if hours < 6 else SAGE
    return _c(code, rel, force=force_color) + _c(DIM, f" @ {clock}", force=force_color)


def die(msg: str, code: int = 1) -> None:
    print(msg, file=sys.stderr)
    sys.exit(code)


# ─── credential store (keychain on macOS, file on Linux) ───────────────────

def read_active_credentials() -> str | None:
    """Return raw credentials JSON string, or None if missing."""
    if sys.platform == "darwin":
        r = subprocess.run(
            ["security", "find-generic-password", "-s", KEYCHAIN_SERVICE, "-w"],
            capture_output=True, text=True,
        )
        return r.stdout.strip() if r.returncode == 0 and r.stdout.strip() else None
    if LINUX_CREDS_FILE.is_file():
        return LINUX_CREDS_FILE.read_text()
    return None


def write_active_credentials(blob: str) -> None:
    if sys.platform == "darwin":
        subprocess.run(
            ["security", "add-generic-password", "-U",
             "-s", KEYCHAIN_SERVICE, "-a", KEYCHAIN_ACCOUNT, "-w", blob],
            check=True,
        )
        return
    LINUX_CREDS_FILE.parent.mkdir(parents=True, exist_ok=True)
    LINUX_CREDS_FILE.write_text(blob)
    os.chmod(LINUX_CREDS_FILE, 0o600)


def extract_access_token(blob: str) -> str | None:
    try:
        return json.loads(blob)["claudeAiOauth"]["accessToken"]
    except (json.JSONDecodeError, KeyError, TypeError):
        return None


def token_expires_at(blob: str) -> int | None:
    """Return expiresAt (unix ms) from a credentials blob, or None."""
    try:
        return int(json.loads(blob)["claudeAiOauth"]["expiresAt"])
    except (json.JSONDecodeError, KeyError, TypeError, ValueError):
        return None


def token_is_expired(blob: str, skew_s: int = REFRESH_SKEW_S) -> bool:
    exp_ms = token_expires_at(blob)
    if exp_ms is None:
        return False  # unknown → let the API call decide
    now_ms = int(datetime.now(timezone.utc).timestamp() * 1000)
    return exp_ms - (skew_s * 1000) <= now_ms


# ─── API calls ─────────────────────────────────────────────────────────────

def api_get(path: str, token: str) -> dict:
    req = urllib.request.Request(
        API_BASE + path,
        headers={
            "Authorization": f"Bearer {token}",
            "anthropic-beta": OAUTH_BETA,
            "User-Agent": USER_AGENT,
        },
    )
    with urllib.request.urlopen(req, timeout=10) as r:
        return json.loads(r.read())




def refresh_blob(blob: str) -> tuple[str | None, str | None]:
    """Exchange the refresh_token for a fresh access_token.

    Returns (new_blob_json, error). The new blob preserves scopes/subscription
    metadata from the old blob and updates accessToken, refreshToken, expiresAt
    from the token endpoint. The server rotates refresh_token on each call.
    """
    try:
        old = json.loads(blob)
        refresh = old["claudeAiOauth"]["refreshToken"]
    except (json.JSONDecodeError, KeyError, TypeError):
        return None, "credentials blob missing refreshToken"

    req = urllib.request.Request(
        OAUTH_TOKEN_URL,
        data=json.dumps({
            "grant_type": "refresh_token",
            "refresh_token": refresh,
            "client_id": OAUTH_CLIENT_ID,
        }).encode(),
        headers={
            "Content-Type": "application/json",
            "Accept": "application/json",
            "User-Agent": USER_AGENT,
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=10) as r:
            resp = json.loads(r.read())
    except urllib.error.HTTPError as e:
        body = ""
        try:
            body = e.read().decode()[:200]
        except Exception:
            pass
        return None, f"refresh: HTTP {e.code} {e.reason} {body}".strip()
    except Exception as e:
        return None, f"refresh: {e}"

    access = resp.get("access_token")
    new_refresh = resp.get("refresh_token", refresh)
    expires_in = int(resp.get("expires_in") or 0)
    if not access:
        return None, "refresh: response missing access_token"

    expires_at_ms = int(datetime.now(timezone.utc).timestamp() * 1000) + expires_in * 1000
    oauth = dict(old.get("claudeAiOauth", {}))
    oauth["accessToken"] = access
    oauth["refreshToken"] = new_refresh
    oauth["expiresAt"] = expires_at_ms
    # scopes come back space-delimited on refresh; preserve original list shape
    new = dict(old)
    new["claudeAiOauth"] = oauth
    return json.dumps(new), None


def fetch_profile_and_usage(token: str) -> tuple[dict | None, dict | None, str | None]:
    try:
        profile = api_get("/api/oauth/profile", token)
    except urllib.error.HTTPError as e:
        return None, None, f"profile: HTTP {e.code} {e.reason}"
    except Exception as e:
        return None, None, f"profile: {e}"
    try:
        usage = api_get("/api/oauth/usage", token)
    except urllib.error.HTTPError as e:
        return profile, None, f"usage: HTTP {e.code} {e.reason}"
    except Exception as e:
        return profile, None, f"usage: {e}"
    return profile, usage, None


# ─── slot storage ──────────────────────────────────────────────────────────

def slot_dir(name: str) -> Path:
    return SLOTS_DIR / name


def list_slot_names() -> list[str]:
    if not SLOTS_DIR.is_dir():
        return []
    return sorted(p.name for p in SLOTS_DIR.iterdir() if p.is_dir())


# ─── per-slot credential storage (Keychain on macOS, file on Linux) ────────
# Slots avoid leaving plaintext OAuth tokens on disk on macOS by storing each
# blob in the login Keychain under service "cc-auth", account = slot name.
# Linux falls back to a chmod-600 file (no system-wide secret store assumed).

def slot_creds_read(name: str) -> str | None:
    if sys.platform == "darwin":
        r = subprocess.run(
            ["security", "find-generic-password",
             "-s", SLOT_KEYCHAIN_SERVICE, "-a", name, "-w"],
            capture_output=True, text=True,
        )
        if r.returncode == 0 and r.stdout.strip():
            return r.stdout.strip()
        # one-shot migration: legacy on-disk slot → keychain, then remove file
        legacy = slot_dir(name) / "credentials.json"
        if legacy.is_file():
            blob = legacy.read_text()
            slot_creds_write(name, blob)
            try:
                legacy.unlink()
            except OSError:
                pass
            return blob
        return None
    legacy = slot_dir(name) / "credentials.json"
    return legacy.read_text() if legacy.is_file() else None


def slot_creds_write(name: str, blob: str) -> None:
    if sys.platform == "darwin":
        subprocess.run(
            ["security", "add-generic-password", "-U",
             "-s", SLOT_KEYCHAIN_SERVICE, "-a", name, "-w", blob],
            check=True,
        )
        return
    f = slot_dir(name) / "credentials.json"
    f.parent.mkdir(parents=True, exist_ok=True)
    f.write_text(blob)
    os.chmod(f, 0o600)


def slot_creds_delete(name: str) -> None:
    if sys.platform == "darwin":
        subprocess.run(
            ["security", "delete-generic-password",
             "-s", SLOT_KEYCHAIN_SERVICE, "-a", name],
            capture_output=True,
        )
    legacy = slot_dir(name) / "credentials.json"
    if legacy.is_file():
        try:
            legacy.unlink()
        except OSError:
            pass


def load_json(p: Path) -> dict | None:
    if not p.is_file():
        return None
    try:
        return json.loads(p.read_text())
    except json.JSONDecodeError:
        return None


def save_slot(name: str, blob: str, refresh: bool = True) -> None:
    d = slot_dir(name)
    d.mkdir(parents=True, exist_ok=True)  # holds profile.json / usage.json (non-secret)
    slot_creds_write(name, blob)

    if not refresh:
        return
    token = extract_access_token(blob)
    if not token:
        print(f"  warning: no access token in blob for {name}", file=sys.stderr)
        return
    profile, usage, err = fetch_profile_and_usage(token)
    if profile is not None:
        (d / "profile.json").write_text(json.dumps(profile, indent=2))
    if usage is not None:
        usage["_fetched_at"] = datetime.now(timezone.utc).isoformat()
        (d / "usage.json").write_text(json.dumps(usage, indent=2))
    if err:
        print(f"  warning: {err}", file=sys.stderr)


def slot_email(name: str) -> str:
    prof = load_json(slot_dir(name) / "profile.json")
    if prof:
        return prof.get("account", {}).get("email", "") or ""
    return ""


def slot_tier(name: str) -> str:
    prof = load_json(slot_dir(name) / "profile.json")
    if prof:
        return prof.get("organization", {}).get("rate_limit_tier", "") or ""
    return ""


def _token_fingerprint(token: str) -> str:
    return hashlib.sha256(token.encode()).hexdigest()[:16]


def _load_identity_cache() -> dict:
    return load_json(ACTIVE_IDENTITY_CACHE) or {}


def _save_identity_cache(cache: dict) -> None:
    ACTIVE_IDENTITY_CACHE.parent.mkdir(parents=True, exist_ok=True)
    ACTIVE_IDENTITY_CACHE.write_text(json.dumps(cache, indent=2))


def identify_active_email(blob: str | None = None) -> str | None:
    """Return the email of the active credentials, using a fingerprint cache.

    Falls back to /api/oauth/profile on cache miss; result is memoized keyed on
    the access-token fingerprint so rotations naturally invalidate the entry.
    """
    if blob is None:
        blob = read_active_credentials()
    if not blob:
        return None
    token = extract_access_token(blob)
    if not token:
        return None
    fp = _token_fingerprint(token)
    cache = _load_identity_cache()
    if fp in cache:
        return cache[fp] or None
    profile, _usage, err = fetch_profile_and_usage(token)
    email: str | None = None
    if profile:
        email = profile.get("account", {}).get("email") or None
    if email:
        # prune to keep the cache from growing unbounded; we only ever need the
        # most recent fingerprint for the active identity flow.
        cache = {fp: email}
        _save_identity_cache(cache)
    return email


def _slot_match_by_token(token: str) -> str | None:
    for name in list_slot_names():
        blob = slot_creds_read(name)
        if blob and extract_access_token(blob) == token:
            return name
    return None


def _slot_match_by_email(email: str) -> str | None:
    for name in list_slot_names():
        if slot_email(name).lower() == email.lower():
            return name
    return None


def sync_active_to_slot(*, verbose: bool = True) -> str | None:
    """Reconcile the active credentials with whichever slot they belong to.

    Refresh-token rotation means `claude` (or any other tool) can rotate the
    active blob's accessToken/refreshToken pair without cc-auth's knowledge,
    leaving the originating slot pointing at a now-revoked refresh token. This
    finds the owning slot by stable identity (account email cached in
    profile.json) and overwrites the slot's stored blob with the active one,
    self-healing the rotation drift before any refresh is attempted.

    Returns the matched slot name (or None). Quiet when the slot was already in
    sync; logs a one-line stderr note when a write actually happens.
    """
    active = read_active_credentials()
    if not active:
        return None
    token = extract_access_token(active)
    if not token:
        return None
    # cheap path: accessToken still matches a slot exactly → nothing to do.
    n = _slot_match_by_token(token)
    if n is not None:
        return n
    # drifted: identify the active account and rewrite the matching slot.
    email = identify_active_email(active)
    if not email:
        return None
    n = _slot_match_by_email(email)
    if n is None:
        return None
    slot_creds_write(n, active)
    if verbose:
        print(_c(DIM, f"synced rotated credentials → slot {n}"),
              file=sys.stderr, flush=True)
    return n


def find_current_slot() -> str | None:
    """Name of the slot matching the active credentials, syncing on drift."""
    return sync_active_to_slot(verbose=True)


# ─── commands ──────────────────────────────────────────────────────────────

def cmd_save(name: str | None) -> None:
    blob = read_active_credentials()
    if not blob:
        die("No active Claude credentials found. Log in with `claude` first.")
    if not name:
        token = extract_access_token(blob)
        profile, _, err = fetch_profile_and_usage(token) if token else (None, None, "no token")
        email = (profile or {}).get("account", {}).get("email") if profile else None
        if not email:
            die(f"Could not auto-detect email for default slot name ({err or 'no email in profile'}). Pass a name explicitly.")
        name = email
    save_slot(name, blob)
    print(f"Saved slot: {name}  ({slot_email(name) or 'email unknown'}, {slot_tier(name) or 'tier unknown'})")


def _slot_picker_line(n: str, current: str | None, *, color: bool = False) -> str:
    usage = load_json(slot_dir(n) / "usage.json") or {}
    fh = usage.get("five_hour") or {}
    sd = usage.get("seven_day") or {}
    tier = (slot_tier(n) or "-").replace("default_claude_", "").replace("_", " ")
    marker = "●" if n == current else " "
    marker_s = _c(ACCENT, marker, force=color) if color else marker
    name_s = _c(BOLD, f"{n:<26.26}", force=color) if color else f"{n:<26.26}"
    tier_s = _c(LABEL, f"{tier:<10.10}", force=color) if color else f"{tier:<10.10}"

    fh_pct = fh.get("utilization")
    sd_pct = sd.get("utilization")
    # 7d is the hard ceiling: when it's saturated you can't spend 5h capacity
    # either, so show the 5h bar as tapped out rather than whatever residual
    # fraction it held at rollover.
    if isinstance(sd_pct, (int, float)) and sd_pct >= 100:
        fh_pct = 100
    fh_bar = sparkbar(fh_pct, 10, force_color=color)
    sd_bar = sparkbar(sd_pct, 10, force_color=color)
    fh_pct_s = color_pct(fh_pct, force_color=color)
    sd_pct_s = color_pct(sd_pct, force_color=color)
    # show the reset for whichever bucket is actually blocking capacity: if
    # the 7d window is saturated (or the 5h window has no active reset), the
    # 5h reset is meaningless — the 7d rollover is when the account returns.
    binding_is_sd = (
        (isinstance(sd_pct, (int, float)) and sd_pct >= 100)
        or not fh.get("resets_at")
    )
    reset_iso = sd.get("resets_at") if binding_is_sd else fh.get("resets_at")
    # if the slot's stored access token is expired and we couldn't refresh it,
    # the cached usage (and any `resets_at`) is frozen at the last successful
    # poll — rendering "expired" against that frozen timestamp is misleading,
    # so flag the slot as stale instead and prompt for re-login.
    blob = slot_creds_read(n)
    if blob and token_is_expired(blob, skew_s=0):
        reset_s = _c(BRICK, "stale", force=color) + _c(DIM, " (re-login)", force=color)
    else:
        reset_s = color_reset_hint(reset_iso, force_color=color)

    lbl_5h = _c(LABEL, "5h", force=color) if color else "5h"
    lbl_7d = _c(LABEL, "7d", force=color) if color else "7d"
    lbl_rs = _c(LABEL, "↻", force=color) if color else "resets"

    return (f"{marker_s} {name_s}  {tier_s}  "
            f"{lbl_5h} {fh_bar} {fh_pct_s}   "
            f"{lbl_7d} {sd_bar} {sd_pct_s}   "
            f"{lbl_rs} {reset_s}")


def pick_slot_interactively() -> str | None:
    names = list_slot_names()
    if not names:
        die("No slots saved.")
    current = find_current_slot()
    if shutil.which("fzf") and sys.stdin.isatty():
        # prepend raw slot name as a hidden tab-delimited field so parsing the
        # selection doesn't depend on the visible marker/whitespace layout.
        lines = [f"{n}\t{_slot_picker_line(n, current, color=True)}" for n in names]
        header = _c(LABEL, f"  {'slot':<26}  {'tier':<10}  "
                           f"{'5h utilization':<18}   {'7d utilization':<18}   resets", force=True)
        r = subprocess.run(
            ["fzf", "--ansi", "--prompt=switch to> ", "--height=40%", "--reverse",
             "--header=" + header, "--delimiter=\t", "--with-nth=2..", "--nth=2.."],
            input="\n".join(lines), capture_output=True, text=True,
        )
        if r.returncode != 0 or not r.stdout.strip():
            return None
        return r.stdout.split("\t", 1)[0]

    # fallback: numbered stdin prompt (plain, works anywhere)
    lines = [_slot_picker_line(n, current, color=_color_enabled()) for n in names]
    print(_c(LABEL, "Saved slots:"))
    for i, line in enumerate(lines, 1):
        print(f"  {i:>2}) {line}")
    try:
        choice = input("pick number (or blank to cancel)> ").strip()
    except (EOFError, KeyboardInterrupt):
        return None
    if not choice:
        return None
    if not choice.isdigit() or not (1 <= int(choice) <= len(names)):
        die(f"Invalid selection: {choice}")
    return names[int(choice) - 1]


def cmd_switch(name: str | None) -> None:
    names = list_slot_names()
    if not names:
        die("No slots saved.")
    # force-refresh all slots so the picker (and any named slot) shows live data
    _refresh_stale_slots(names, force=True)
    if not name:
        name = pick_slot_interactively()
        if not name:
            print("(cancelled)")
            return
    blob = slot_creds_read(name)
    if blob is None:
        die(f"No such slot: {name}")
    blob, refresh_err = _maybe_refresh_credentials(name, blob)
    if refresh_err:
        if token_is_expired(blob):
            die(f"slot {name}: credentials expired and refresh failed: {refresh_err}\n"
                f"  re-login: `claude` then `cc-auth save {name}`")
        print(_c(DIM, f"  warning: {refresh_err}"), file=sys.stderr)
    write_active_credentials(blob)
    print(f"Switched to slot: {name}  ({slot_email(name) or 'email unknown'})")
    print("Restart Claude Code sessions to pick up the change.")


